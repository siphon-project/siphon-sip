<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  B2BUA reliable-provisional interworking — B-leg UAS (IR.92-style 100rel).

  recv INVITE → 100 → reliable 183 (Require: 100rel, RSeq: 42) → recv PRACK
  (siphon auto-PRACKs the B-leg) → 200 PRACK → 200 INVITE → recv ACK → recv
  BYE → 200 BYE.

  Registered as bob (172.20.0.52) by sipp-b2bua-register.  siphon dials this
  contact for the B-leg, sees the reliable 183, PRACKs it locally, and answers
  the A-leg with a sanitized (non-reliable) 183.

  Pair with b2bua_reliable_prov_uac.xml on the A-leg side of siphon.
-->
<scenario name="B2BUA reliable-provisional UAS (100rel)">

  <recv request="INVITE" crlf="true">
    <!-- Snapshot the INVITE so the final 200 OK can be rebuilt AFTER the PRACK
         round-trip (where [last_*] would otherwise refer to the PRACK). -->
    <action>
      <ereg regexp="(.*)" search_in="hdr" header="Via:" assign_to="junk,invite_via" />
      <ereg regexp="(.*)" search_in="hdr" header="From:" assign_to="junk,invite_from" />
      <ereg regexp="(.*)" search_in="hdr" header="To:" assign_to="junk,invite_to" />
      <ereg regexp="(.*)" search_in="hdr" header="Call-ID:" assign_to="junk,invite_callid" />
      <ereg regexp="(.*)" search_in="hdr" header="CSeq:" assign_to="junk,invite_cseq" />
    </action>
  </recv>

  <send>
    <![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- Reliable 183 with RSeq=42 + SDP (early media) -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 183 Session Progress
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Require: 100rel
RSeq: 42
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
]]>
  </send>

  <!-- siphon (B2BUA, B-leg side) auto-PRACKs the reliable 183.  The PRACK MUST
       carry the early-dialog To-tag from the 183 (RFC 3262 §4 — PRACK is
       in-dialog); a strict IMS UAS 481s a tag-less PRACK.  check_it fails the
       call if the To header has no matching tag. -->
  <recv request="PRACK" crlf="true">
    <action>
      <ereg regexp="tag=[0-9]+SIPpTag01[0-9]+" search_in="hdr" header="To:"
            check_it="true" assign_to="prack_to_tag" />
      <!-- SIPp requires an assigned variable to be referenced; the log both
           satisfies that and records the matched early-dialog To-tag. -->
      <log message="PRACK carries early-dialog To-tag [$prack_to_tag]" />
    </action>
  </recv>

  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- Final 200 for the INVITE — rebuilt from the stored INVITE header values,
       same To-tag as the early-dialog 183. -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
Via:[$invite_via]
From:[$invite_from]
To:[$invite_to];tag=[pid]SIPpTag01[call_number]
Call-ID:[$invite_callid]
CSeq:[$invite_cseq]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
]]>
  </send>

  <recv request="ACK" optional="true" timeout="5000" />

  <recv request="BYE" />

  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

</scenario>
